# ══════════════════════════════════════════════════════════════════════════════
#  Travel Brain — Environment Variables
#  Copy this to .env and fill in your keys.  NEVER commit .env to git.
# ══════════════════════════════════════════════════════════════════════════════

# ── LLM for Chat Answers (pick ONE — Gemini is FREE) ─────────────────────────
# Option A: Gemini (RECOMMENDED — free tier at aistudio.google.com/apikey)
GEMINI_API_KEY=AIza...

# Option B: OpenAI (paid — needs $5+ credit at platform.openai.com/billing)
# OPENAI_API_KEY=sk-...

# The system auto-detects which key you've set.
# To override: LLM_PROVIDER=gemini   or   LLM_PROVIDER=openai
# LLM_PROVIDER=

# ── Data Sources (for populating the knowledge base) ─────────────────────────
# Reddit API — free at reddit.com/prefs/apps → "create another app" → script
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
REDDIT_USER_AGENT=TravelBrainBot/1.0 by YourRedditUsername

# YouTube Data API v3 — free at console.cloud.google.com
# (same Google account as Gemini, just enable "YouTube Data API v3")
YOUTUBE_API_KEY=...

# ── Vector Database ───────────────────────────────────────────────────────────
# ChromaDB is used by default (local, no key needed)
CHROMA_PERSIST_DIR=./data/chroma_db

# Pinecone (optional — for production cloud hosting)
# PINECONE_API_KEY=...
# PINECONE_ENVIRONMENT=us-east-1
# PINECONE_INDEX_NAME=travel-brain

# ── Pipeline Settings ─────────────────────────────────────────────────────────
# Embeddings: "local" uses sentence-transformers (free, runs on CPU)
#             "openai" uses text-embedding-3-small (paid, better quality)
EMBEDDING_PROVIDER=local

# Vector DB: "chroma" = local SQLite-based (free); "pinecone" = cloud
VECTOR_DB_PROVIDER=chroma

# Max docs to scrape per source per run (lower for testing)
SCRAPE_LIMIT=50

LOG_LEVEL=INFO
